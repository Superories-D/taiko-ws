# Public port opened on this server.
PORT=34802
BIND_ADDRESS=0.0.0.0
# Hard admission limit enforced by this WebSocket server. Match it to the Admin limit.
MAX_CONNECTIONS=100
# Per-connection flood protection. 120 leaves ample headroom for normal gameplay.
MAX_MESSAGES_PER_SECOND=120

# Comma-separated exact origins of the Taiko Web site allowed to open WebSockets.
ALLOWED_ORIGINS=https://taiko.example.com
